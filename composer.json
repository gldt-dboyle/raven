{
    "name": "gldt/raven",
    "description": "Carry Laravel Nightwatch issues into GitHub issues via webhooks.",
    "keywords": ["laravel", "nightwatch", "github", "issues", "webhooks", "monitoring"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/bus": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Gldt\\Raven\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gldt\\Raven\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gldt\\Raven\\RavenServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
